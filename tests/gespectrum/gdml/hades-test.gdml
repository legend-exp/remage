			<rzpoint r="0.0" z="0.0"/>
			<rzpoint r="49.3" z="0.0"/>
			<rzpoint r="49.3" z="119.9"/>
			<rzpoint r="0.0" z="119.9"/>
		</genericPolycone>
		<polycone name="wrap" startphi="0" deltaphi="TWOPI" lunit="mm" aunit="rad">
