			<zplane rmin="0" rmax="CuSource_holder_radius" z="CuSource_holder_z"/>
			<zplane rmin="0" rmax="CuSource_holder_bottom_radius" z="CuSource_holder_z"/>
			<zplane rmin="0" rmax="CuSource_holder_bottom_radius" z="CuSource_holder_all_z"/>
		</polycone>
		<polycone name="source_holder" startphi="0" deltaphi="TWOPI" lunit="mm" aunit="rad">
			<zplane rmin="source_holder_top_plate_radius" rmax="source_holder_outer_radius" z="0"/>
			<zplane rmin="source_holder_top_plate_radius" rmax="source_holder_outer_radius" z="source_holder_top_plate_z"/>
			<zplane rmin="source_holder_top_inner_radius" rmax="source_holder_outer_radius" z="source_holder_top_plate_z"/>
			<zplane rmin="source_holder_top_inner_radius" rmax="source_holder_outer_radius" z="source_holder_top_z"/>
			<zplane rmin="source_holder_inner_radius" rmax="source_holder_outer_radius" z="source_holder_top_z"/>
			<zplane rmin="source_holder_inner_radius" rmax="source_holder_outer_radius" z="source_holder_cryostat_z"/>
			<zplane rmin="source_holder_bottom_inner_radius" rmax="source_holder_outer_radius" z="source_holder_cryostat_z"/>
			<zplane rmin="source_holder_bottom_inner_radius" rmax="source_holder_outer_radius" z="source_holder_z"/>
		</polycone>
		<box name="bottom_plate" x="bottom_plate_x" y="bottom_plate_y" z="bottom_plate_z" lunit="mm"/>
		<box name="cavity_bottom_plate" x="cavity_bottom_plate_x" y="cavity_bottom_plate_y" z="cavity_bottom_plate_z" lunit="mm"/>
		<subtraction name="final_bottom_plate">
			<first ref="bottom_plate"/>
			<second ref="cavity_bottom_plate"/>
			<position name="final_bottom_plate_translation" x="0.0" y="(bottom_plate_y)/2" z="0.0" unit="mm"/>
		</subtraction>
		<box name="base_lead_castle_1" x="base_x_1" y="base_y_1" z="base_z_1" lunit="mm"/>
		<box name="inner_cavity_base_1" x="inner_cavity_x_1" y="inner_cavity_y_1" z="inner_cavity_z_1" lunit="mm"/>
		<box name="cavity_base_1" x="cavity_x_1" y="cavity_y_1" z="cavity_z_1" lunit="mm"/>
		<union name="total_cavity_1">
			<first ref="inner_cavity_base_1"/>
			<second ref="cavity_base_1"/>
			<position name="total_cavity_1_translation" x="0.0" y="(inner_cavity_y_1/2+(base_y_1-inner_cavity_y_1)/4)" z="(inner_cavity_z_1-cavity_z_1)/2" unit="mm"/>
		</union>
		<subtraction name="base_cavity_1">
			<first ref="base_lead_castle_1"/>
			<second ref="total_cavity_1"/>
		</subtraction>
		<box name="top_lead_castle_1" x="top_x_1" y="top_y_1" z="top_z_1" lunit="mm"/>
		<union name="top_base_1">
			<first ref="base_cavity_1"/>
			<second ref="top_lead_castle_1"/>
			<position name="top_base_1_translation" x="0.0" y="0.0" z="-(base_z_1+top_z_1)/2 - 0.01" unit="mm"/>
		</union>
		<box name="front_1" x="front_x_1" y="front_y_1" z="front_z_1" lunit="mm"/>
		<union name="final_lead_castle_1">
			<first ref="top_base_1"/>
			<second ref="front_1"/>
			<position name="final_lead_castle_1_translation" x="0.0" y="(base_y_1+front_y_1)/2 - 0.01" z="(base_z_1-front_z_1)/2" unit="mm"/>
		</union>
