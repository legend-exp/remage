		<polycone name="CuSource_holder_cavity" startphi="0" deltaphi="TWOPI" lunit="mm" aunit="rad">
			<zplane rmin="0" rmax="CuSource_holder_cavity_radius" z="0"/>
			<zplane rmin="0" rmax="CuSource_holder_cavity_radius" z="CuSource_holder_all_z"/>
		</polycone>
		<polycone name="CuSource_holder" startphi="0" deltaphi="TWOPI" lunit="mm" aunit="rad">
