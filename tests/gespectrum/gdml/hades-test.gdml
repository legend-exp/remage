			<zplane rmin="0" rmax="wrap_radius" z="wrap_top_thickness"/>
			<zplane rmin="wrap_cavity_radius" rmax="wrap_radius" z="wrap_top_thickness"/>
			<zplane rmin="wrap_cavity_radius" rmax="wrap_radius" z="wrap_z"/>
		</polycone>
